<idea-plugin>
    <id>com.yii2storm.modelmagic</id>
    <name>Yii2Storm Model Magic</name>
    <vendor email="support@yii2storm.com">Yii2Storm</vendor>

    <idea-version since-build="251" until-build="251.*"/>

    <description><![CDATA[
        <html>
        <body>
        <p>Improves Yii2 model magic property support in PhpStorm.</p>
        <ul>
            <li>Completion for model magic properties</li>
            <li>Go to declaration for getters, setters, relations, attributes and PHPDoc declarations</li>
            <li>Reference resolution for model magic properties</li>
            <li>Unknown property inspection</li>
            <li>Type inference for getter, setter, relation, PHPDoc and attributes() sources</li>
            <li>Supports inheritance and traits</li>
        </ul>
        </body>
        </html>
    ]]></description>

    <depends>com.intellij.modules.phpstorm</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">
        <completion.contributor language="PHP" implementationClass="com.yii2storm.modelmagic.completion.MagicPropertyCompletionContributor"/>
        <psi.referenceContributor language="PHP" implementation="com.yii2storm.modelmagic.reference.MagicPropertyReferenceContributor"/>
        <annotator language="PHP" implementationClass="com.yii2storm.modelmagic.annotator.MagicPropertyAnnotator"/>
        <localInspection
                language="PHP"
                shortName="Yii2UnknownMagicProperty"
                displayName="Unknown Yii2 model magic property"
                groupName="Yii2"
                enabledByDefault="true"
                implementationClass="com.yii2storm.modelmagic.inspection.MagicPropertyInspection"/>
        <php.typeProvider4 implementation="com.yii2storm.modelmagic.type.MagicPropertyTypeProvider"/>
        <gotoDeclarationHandler implementation="com.yii2storm.modelmagic.navigation.MagicPropertyGotoDeclarationHandler"/>
    </extensions>
</idea-plugin>
